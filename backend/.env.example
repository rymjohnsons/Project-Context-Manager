# Copy this file to .env and fill in your values.
# .env is gitignored and never committed — .env.example is safe to commit.

# Database connection string.
# Local development:  sqlite:///./data.db  (no setup needed)
# Railway PostgreSQL: automatically injected when you add the PostgreSQL plugin
DATABASE_URL=sqlite:///./data.db

# Secret key used to sign JWT tokens.
# Use a long random string in production — anyone with this key can forge tokens.
# Generate one with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-this-with-a-long-random-secret
